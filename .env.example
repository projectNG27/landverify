# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Private bucket for intake uploads (create in Supabase → Storage; default name below)
SUPABASE_STORAGE_BUCKET_REQUEST_DOCS=request-documents

# Mailgun (https://documentation.mailgun.com/)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=
# Optional: EU domains often use https://api.eu.mailgun.net
MAILGUN_API_BASE=

# Inbox for “new requester message” alerts (case channel on tracking page)
ADMIN_NOTIFY_EMAIL=

# Paystack (https://paystack.com/docs)
# Secret key: used for REST + webhook HMAC (do not expose to the browser)
PAYSTACK_SECRET_KEY=

# Optional: full URL to *this* app's Paystack browser return handler, including path /pay/callback.
# If unset, callback is {NEXT_PUBLIC_SITE_URL}/pay/callback?reference=…
# Use when Paystack must return to a different origin than NEXT_PUBLIC_SITE_URL (e.g. ngrok during local tests):
# PAYSTACK_CALLBACK_URL=https://your-tunnel.example/pay/callback

# App URL (used for Paystack callback when PAYSTACK_CALLBACK_URL is unset, links in email, webhook docs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin blog publishing (single admin)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
AGENT_AUTH_PEPPER=

# GitHub content publishing target (format: owner/repo)
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_CONTENT_TOKEN=
