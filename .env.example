# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Private bucket for intake uploads (create in Supabase → Storage; default name below)
SUPABASE_STORAGE_BUCKET_REQUEST_DOCS=request-documents

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=

# App URL (used in emails and redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin blog publishing (single admin)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
AGENT_AUTH_PEPPER=

# GitHub content publishing target (format: owner/repo)
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_CONTENT_TOKEN=
